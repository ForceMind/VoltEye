# docker 对外端口（docker-compose 用）
HOST_PORT=3000

PORT=3000
TZ=Asia/Shanghai

# 唐巢登录手机号（必填）
SITE_MOBILE=
# 唐巢登录密码（明文，服务端会转 SHA256 后调用接口）
SITE_PASSWORD=

# 采集间隔（分钟）
POLL_INTERVAL_MINUTES=30
# 存储上限（条）
MAX_RECORDS=10000

# 自动识别失败时可手工指定
CONTRACT_ID=
SMART_KEY=

# 低余额告警
LOW_BALANCE_THRESHOLD=50
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_HOURS=6

# 手动触发采集接口鉴权
SYNC_API_KEY=

# 本地数据文件
DATA_FILE=./data/balance-history.json
